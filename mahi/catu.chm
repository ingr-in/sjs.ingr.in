class TagConverter{static #defaults={xyz:"div",yzx:"span",abc:"p"};constructor(map={}){this.map={...TagConverter.#defaults,...map};this.observer=null}convert(el){const tag=this.map[el?.tagName?.toLowerCase()];if(!tag)return;const fresh=document.createElement(tag);fresh.innerHTML=el.innerHTML;for(let{name,value}of el.attributes){fresh.setAttribute(name,value)}el.replaceWith(fresh);return fresh}convertAll(selector=Object.keys(this.map).join()){document.querySelectorAll(selector).forEach(el=>this.convert(el))}watch(selector=Object.keys(this.map).join()){this.observer?.disconnect();this.observer=new MutationObserver(mutations=>{for(let{addedNodes}of mutations){for(let node of addedNodes){if(node.nodeType===1){if(node.matches?.(selector))this.convert(node);node.querySelectorAll?.(selector).forEach(el=>this.convert(el))}}}});this.observer.observe(document.body,{childList:true,subtree:true});return this}stop(){this.observer?.disconnect();this.observer=null}}const converter=new TagConverter();converter.convertAll();converter.watch();
